# turbo-llm-service configuration
#
# ENGINE: auto | vllm | tgi | onnx
#   auto → proxy(vLLM) when a GPU or UPSTREAM_URL is present, else onnx (CPU)
ENGINE=auto

# DEVICE: auto | cuda | cpu | mps
DEVICE=auto

# HuggingFace model id served by the engine.
MODEL_NAME=Qwen/Qwen2.5-3B-Instruct

# Proxy mode: OpenAI-compatible upstream (vLLM or TGI). Used when ENGINE is
# vllm/tgi/proxy or auto-resolves to a proxy.
UPSTREAM_URL=http://vllm:8000

# Informational / parity with turboquant-service.
KV_CACHE_BITS=4
MAX_CONTEXT_LENGTH=8192

# ONNX (CPU) engine only:
#   CPUExecutionProvider (default) or OpenVINOExecutionProvider (optimum-intel)
ONNX_PROVIDER=CPUExecutionProvider

# Allow HF repos that execute custom Python on load. Keep false unless trusted.
TRUST_REMOTE_CODE=false

# Comma-separated CORS origins, or * for local dev.
CORS_ORIGINS=*

# ── Model lifecycle (load only what's used) ────────────────────────────────
# Unload weights after this many idle seconds (frees VRAM/RAM). Lower = more
# aggressive sharing; higher = fewer reloads for frequent use.
MODEL_IDLE_TTL=120
# Redis enables the cross-service single-GPU lease so only one model is resident
# at a time. Without it you still get per-service lazy load + idle eviction.
REDIS_URL=redis://redis:6379
# This service's identity in the GPU lease, and the lease renewal TTL.
GPU_HOLDER_ID=llm
GPU_LEASE_TTL=60
